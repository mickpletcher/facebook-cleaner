{
  "name": "facebook-cleaner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "validate": "node ./node_modules/tsx/dist/cli.mjs ./src/cli.ts --validate-only",
    "import": "node ./node_modules/tsx/dist/cli.mjs ./src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "stream-chain": "^4.2.5",
    "stream-json": "^3.5.0"
  }
}
